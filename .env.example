# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Public URL of this app (used in re-auth email links)
APP_URL=https://your-app.azurewebsites.net/

# PostgreSQL connection string (omit to use local SQLite for dev)
DATABASE_URL=postgresql://username:password@hostname/dbname

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be an address on a domain you've verified in Resend.
# Use onboarding@resend.dev for quick testing (delivers only to your own account email).
RESEND_FROM_EMAIL=briefs@yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────────────
# Port (default 5001 for plain python, 8000 for gunicorn/Docker)
PORT=8000

# Set to "true" to skip the Resend API call and just log — dev only, no delivery
RESEND_DRY_RUN=false

# SQLite path, only used when DATABASE_URL is not set
# DB_PATH=./ontracker.db
