{
  "manifest_version": 3,
  "key": "",
  "name": "OnTrack Brief",
  "version": "1.1",
  "description": "Keeps your OnTrack Brief token fresh automatically.",
  "permissions": ["storage", "cookies"],
  "host_permissions": [
    "https://ontrack.deakin.edu.au/*",
    "http://localhost:5001/*",
    "http://localhost:8000/*",
    "http://localhost:5173/*",
    "https://on-tracker.com/*",
    "https://*.clerk.accounts.dev/*",
    "https://*.azurewebsites.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OnTrack Brief"
  },
  "content_scripts": [
    {
      "matches": ["https://ontrack.deakin.edu.au/*"],
      "js": ["config.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "config.js"],
      "matches": ["https://ontrack.deakin.edu.au/*"]
    }
  ]
}
